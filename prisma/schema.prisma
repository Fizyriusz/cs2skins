generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Skin {
  id               String               @id @default(cuid())
  name             String
  weapon           String
  collection       String
  rarity           String
  minFloat         Float
  maxFloat         Float
  floatRequiredMin Float?
  floatRequiredMax Float?
  notes            String?
  isActiveDrop     Boolean              @default(true)
  totalSupply      Int                  @default(0)
  marketData       MarketData[]
  blueprintsTarget TradeUpBlueprint[]   @relation("TargetSkin")
  simulationsTarget TradeUpSimulation[] @relation("TargetSim")
  simulationsInput TradeUpSimulation[]  @relation("InputSim")
  usageStats       UsageStat[]
}

model MarketData {
  id            String   @id @default(cuid())
  skinId        String
  skin          Skin     @relation(fields: [skinId], references: [id])
  condition     String
  stattrak      Boolean  @default(false)
  steamPrice    Float
  externalPrice Float?
  volume        Int?
  timestamp     DateTime @default(now())
}

model UsageStat {
  id        String   @id @default(cuid())
  skinId    String
  skin      Skin     @relation(fields: [skinId], references: [id])
  month     String   // "YYYY-MM"
  usage     Int      // Amount applied or added
  createdAt DateTime @default(now())
}

model TradeUpBlueprint {
  id                      String   @id @default(cuid())
  targetSkinId            String
  targetSkin              Skin     @relation("TargetSkin", fields: [targetSkinId], references: [id])
  requiredInputRarity     String
  requiredInputCollection String
}

model TradeUpSimulation {
  id                String   @id @default(cuid())
  
  targetSkinId      String
  targetSkin        Skin     @relation("TargetSim", fields: [targetSkinId], references: [id])
  targetCondition   String
  
  inputSkinId       String?
  inputSkin         Skin?    @relation("InputSim", fields: [inputSkinId], references: [id])
  inputCondition    String?
  
  targetAverageFloat Float
  costOf10Inputs    Float
  targetValue       Float
  averageFailValue  Float
  evResult          Float
  timestamp         DateTime @default(now())
}
